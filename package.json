{
  "name": "roulette-quiz",
  "version": "1.0.0",
  "description": "Multiplayer party game combining quiz with Russian Roulette",
  "main": "client/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "server:start": "cd server && npm start",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.roulette-quiz.app",
    "productName": "Roulette Quiz",
    "files": [
      "client/**/*",
      "server/**/*",
      "shared/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
